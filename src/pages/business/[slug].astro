---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { businessUrl, getPublishedBusinessArticles } from '../../lib/business';
import { formatDate } from '../../lib/interviews';
import '../../styles/article.css';

export async function getStaticPaths() {
  const articles = await getCollection('business', ({ data }) => !data.draft);
  return articles.map((article) => ({ params: { slug: article.data.slug }, props: { article } }));
}

const { article } = Astro.props;
const articles = await getPublishedBusinessArticles();
const index = articles.findIndex((item) => item.id === article.id);
const previous = articles[index + 1];
const next = articles[index - 1];
const { Content } = await render(article);
const d = article.data;
const canonical = new URL(businessUrl(article), Astro.site ?? Astro.url.origin).href;
const jsonLd = { '@context': 'https://schema.org', '@type': 'Article', headline: d.title, description: d.description, datePublished: d.publishedAt.toISOString(), dateModified: (d.updatedAt ?? d.publishedAt).toISOString(), author: { '@type': 'Person', name: d.author }, mainEntityOfPage: canonical };
---
<BaseLayout title={`${d.title}｜Business｜人と場のあいだ`} description={d.description} image={d.mainImage} type="article" {jsonLd}>
  <article class="review-detail">
    <header class="review-header"><p class="eyebrow">BUSINESS</p><h1>{d.title}</h1><p class="review-description">{d.description}</p><dl>{d.businessName && <div><dt>Name</dt><dd>{d.businessName}</dd></div>}{d.businessType && <div><dt>Field</dt><dd>{d.businessType}</dd></div>}<div><dt>Published</dt><dd><time datetime={d.publishedAt.toISOString()}>{formatDate(d.publishedAt)}</time></dd></div><div><dt>Written by</dt><dd>{d.author}</dd></div></dl></header>
    {d.mainImage && <figure class="review-cover"><img src={d.mainImage} alt={d.mainImageAlt} /></figure>}
    <div class="article-body"><Content /></div>
    <footer class="article-footer"><p>この記事のテーマ</p><div class="tag-list">{d.tags.map((tag) => <span>#{tag}</span>)}</div></footer>
  </article>
  <nav class="article-pager" aria-label="前後のBusiness記事">{previous ? <a href={businessUrl(previous)}><span>← PREVIOUS</span>{previous.data.title}</a> : <span></span>}{next && <a class="next" href={businessUrl(next)}><span>NEXT →</span>{next.data.title}</a>}</nav>
  <div class="back-link"><a href="/business/">← Business一覧へ戻る</a></div>
</BaseLayout>
