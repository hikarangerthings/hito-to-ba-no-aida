---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { getPublishedInterviews } from '../../lib/interviews';
export async function getStaticPaths() {
  const articles = await getCollection('interviews', ({ data }) => !data.draft);
  return articles.map((article) => ({ params: { slug: article.data.slug }, props: { article } }));
}
const { article } = Astro.props;
const articles = await getPublishedInterviews();
const index = articles.findIndex((a) => a.id === article.id);
const { Content } = await render(article);
const related = articles.filter((a) => a.id !== article.id && a.data.categorySlug === article.data.categorySlug).slice(0, 2);
---
<ArticleLayout {article} previous={articles[index + 1]} next={articles[index - 1]} {related} number={articles.length - index}><Content /></ArticleLayout>
